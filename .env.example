# Runtime
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
CLIENT_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000/api
TRUST_PROXY=1

# MongoDB is required. Use a real MongoDB or MongoDB Atlas URI in your private .env file.
MONGODB_URI=
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_HEARTBEAT_FREQUENCY_MS=10000
MONGODB_CONNECT_RETRIES=3

# Staff authentication. Use long random values in your private .env file.
# When omitted, the server creates secure per-process values so Hostinger can boot; configured values are recommended so admin sessions survive restarts.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=
ADMIN_BOOTSTRAP_TOKEN=

# Browser/API security
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
JSON_BODY_LIMIT=512kb
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=35000
KEEP_ALIVE_TIMEOUT_MS=5000

# Verified public configuration is centralized in server/config/clinic.js.
DEFAULT_TIMEZONE=Asia/Karachi
DOCTOR_RECEPTION_PHONE=+92 335 7504478

# WhatsApp Cloud API. Leave blank until real Meta credentials and approved templates are available.
# Keep false for a web-only launch. Set true after all required Meta credentials are configured.
WHATSAPP_REQUIRED=false
WHATSAPP_API_VERSION=v25.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
WHATSAPP_TEMPLATE_APPOINTMENT_CONFIRMATION=
WHATSAPP_TEMPLATE_APPOINTMENT_REMINDER=
WHATSAPP_TEMPLATE_RESCHEDULE_CONFIRMATION=
WHATSAPP_TEMPLATE_CANCELLATION_CONFIRMATION=

# Logging
LOG_LEVEL=info

# Optional MongoDB performance/connection configurations
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000

# WhatsApp retry settings
WHATSAPP_RETRY_ATTEMPTS=2
WHATSAPP_HTTP_TIMEOUT_MS=15000

# Observability / performance logs
SLOW_REQUEST_MS=2000
